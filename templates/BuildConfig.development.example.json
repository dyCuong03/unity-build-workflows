{
  "$schema": "../schemas/unity-build-config.schema.json",

  "productName": "Example Project [DEV]",
  "outputDirectory": "Builds/Development",

  "scriptingBackend": "Mono",

  "developmentBuild": true,
  "allowDebugging": true,
  "connectProfiler": true,

  "addressables": {
    "enabled": false,
    "profile": "Development",
    "buildRemoteCatalog": false
  },

  "android": {
    "applicationId": "com.example.project.dev",
    "buildAppBundle": false,
    "minSdkVersion": 22,
    "targetSdkVersion": 34,
    "architecture": "ARM64",
    "keystoreMode": "debug",
    "symbolExport": "debugging"
  },

  "iOS": {
    "bundleIdentifier": "com.example.project.dev",
    "marketingVersion": "1.0.0",
    "targetOSVersion": "14.0",
    "architecture": "ARM64",
    "developmentTeamId": "ABCDE12345",
    "signingStyle": "automatic",
    "exportMethod": "development",
    "enableBitcode": false,
    "generateSymbols": false,
    "uploadToTestFlight": false,
    "generateXcodeProjectOnly": false
  },

  "webgl": {
    "compressionFormat": "Disabled",
    "decompressionFallback": false,
    "dataCaching": false,
    "memorySize": 512,
    "outputName": "WebGL_Dev"
  },

  "windows": {
    "outputName": "ExampleProject_Dev",
    "compressOutput": false
  },

  "gates": {
    "maxBuildSizeMB": 1000,
    "warnBuildSizeIncreasePct": 20,
    "failBuildSizeIncreasePct": 50,
    "failOnWarnings": false,
    "requiredValidationRules": [
      "no_missing_scripts"
    ]
  },

  "metadata": {
    "environment": "development"
  },

  "hooks": {
    "preBuild": [],
    "postBuild": []
  }
}
