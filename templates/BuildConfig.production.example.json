{
  "$schema": "../schemas/unity-build-config.schema.json",
  "projectName": "MyUnityGame",
  "companyName": "Acme Studios",
  "productName": "My Unity Game",
  "bundleVersion": "1.0.0",
  "buildNumberStrategy": "github_run_number",

  "outputDirectory": "Builds/Production",

  "scenes": [
    "Assets/Scenes/Boot.unity",
    "Assets/Scenes/MainMenu.unity",
    "Assets/Scenes/Gameplay.unity",
    "Assets/Scenes/GameOver.unity"
  ],

  "scriptingBackend": "IL2CPP",
  "apiCompatibilityLevel": "NET_Standard_2_1",

  "developmentBuild": false,
  "allowDebugging": false,
  "connectProfiler": false,
  "deepProfiling": false,
  "cleanBuildCache": true,

  "runTests": true,

  "addressables": {
    "enabled": true,
    "profile": "Production",
    "buildRemoteCatalog": true
  },

  "android": {
    "applicationId": "com.acmestudios.myunitygame",
    "buildAppBundle": true,
    "minSdkVersion": 22,
    "targetSdkVersion": 34,
    "architecture": "ARM64",
    "keystoreMode": "custom",
    "symbolExport": "public"
  },

  "iOS": {
    "bundleIdentifier": "com.acmestudios.myunitygame",
    "marketingVersion": "1.0.0",
    "targetOSVersion": "14.0",
    "architecture": "ARM64",
    "developmentTeamId": "ABCDE12345",
    "signingStyle": "manual",
    "provisioningProfileSpecifier": "MyUnityGame Distribution",
    "codeSignIdentity": "iPhone Distribution",
    "exportMethod": "app-store-connect",
    "enableBitcode": false,
    "generateSymbols": true,
    "uploadSymbols": true,
    "uploadToTestFlight": false,
    "generateXcodeProjectOnly": false
  },

  "windows": {
    "architecture": "x86_64",
    "outputName": "MyUnityGame",
    "compressOutput": true
  },

  "webgl": {
    "compressionFormat": "Brotli",
    "decompressionFallback": true,
    "dataCaching": true,
    "memorySize": 256,
    "template": "Default",
    "outputName": "WebGL"
  },

  "gates": {
    "maxBuildSizeMB": 500,
    "warnBuildSizeIncreasePct": 5,
    "failBuildSizeIncreasePct": 15,
    "failOnWarnings": true,
    "requiredValidationRules": [
      "no_missing_references",
      "no_missing_scripts",
      "no_missing_prefabs",
      "addressables_content_hash_stable",
      "bundle_identifier_matches_config"
    ]
  },

  "metadata": {
    "repository": "https://github.com/acmestudios/myunitygame",
    "team": "mobile",
    "environment": "production",
    "distribution": "app-store"
  },

  "hooks": {
    "preBuild": ["validate-asset-integrity", "check-legal-notices"],
    "postBuild": ["upload-dsyms", "submit-to-store-connect", "notify-release-channel"]
  }
}
