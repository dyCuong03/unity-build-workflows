{
  "$schema": "../schemas/unity-build-config.schema.json",

  "outputDirectory": "Builds/Production",

  "cleanBuildCache": true,

  "addressables": {
    "enabled": false,
    "profile": "Production",
    "buildRemoteCatalog": true
  },

  "android": {
    "applicationId": "com.example.project",
    "buildAppBundle": true,
    "minSdkVersion": 22,
    "targetSdkVersion": 34,
    "architecture": "ARM64",
    "keystoreMode": "custom",
    "symbolExport": "public"
  },

  "iOS": {
    "bundleIdentifier": "com.example.project",
    "marketingVersion": "1.0.0",
    "targetOSVersion": "14.0",
    "architecture": "ARM64",
    "developmentTeamId": "ABCDE12345",
    "signingStyle": "manual",
    "provisioningProfileSpecifier": "Example Project Distribution",
    "codeSignIdentity": "iPhone Distribution",
    "exportMethod": "app-store-connect",
    "enableBitcode": false,
    "generateSymbols": true,
    "uploadSymbols": true,
    "uploadToTestFlight": false,
    "generateXcodeProjectOnly": false
  },

  "webgl": {
    "compressionFormat": "Brotli",
    "decompressionFallback": true,
    "dataCaching": true,
    "memorySize": 256,
    "outputName": "WebGL"
  },

  "gates": {
    "maxBuildSizeMB": 500,
    "warnBuildSizeIncreasePct": 5,
    "failBuildSizeIncreasePct": 15,
    "failOnWarnings": true,
    "requiredValidationRules": [
      "no_missing_references",
      "no_missing_scripts",
      "no_missing_prefabs",
      "bundle_identifier_matches_config"
    ]
  },

  "metadata": {
    "environment": "production"
  },

  "hooks": {
    "preBuild": [],
    "postBuild": []
  }
}
