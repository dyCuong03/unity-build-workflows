{
  "$schema": "../schemas/unity-build-config.schema.json",

  "outputDirectory": "Builds/Staging",

  "addressables": {
    "enabled": false,
    "profile": "Staging",
    "buildRemoteCatalog": true
  },

  "android": {
    "applicationId": "com.example.project",
    "buildAppBundle": true,
    "minSdkVersion": 22,
    "targetSdkVersion": 34,
    "architecture": "ARM64",
    "keystoreMode": "custom",
    "symbolExport": "public"
  },

  "iOS": {
    "bundleIdentifier": "com.example.project",
    "marketingVersion": "1.0.0",
    "targetOSVersion": "14.0",
    "architecture": "ARM64",
    "developmentTeamId": "ABCDE12345",
    "signingStyle": "manual",
    "provisioningProfileSpecifier": "Example Project AdHoc",
    "codeSignIdentity": "iPhone Distribution",
    "exportMethod": "ad-hoc",
    "enableBitcode": false,
    "generateSymbols": true,
    "uploadSymbols": false,
    "uploadToTestFlight": false,
    "generateXcodeProjectOnly": false
  },

  "webgl": {
    "compressionFormat": "Gzip",
    "decompressionFallback": true,
    "dataCaching": true,
    "memorySize": 256,
    "outputName": "WebGL"
  },

  "gates": {
    "maxBuildSizeMB": 600,
    "warnBuildSizeIncreasePct": 10,
    "failBuildSizeIncreasePct": 30,
    "failOnWarnings": true,
    "requiredValidationRules": [
      "no_missing_references",
      "no_missing_scripts",
      "bundle_identifier_matches_config"
    ]
  },

  "metadata": {
    "environment": "staging"
  },

  "hooks": {
    "preBuild": [],
    "postBuild": []
  }
}
