{
  "$schema": "../schemas/unity-build-config.schema.json",
  "projectName": "ExampleProject",
  "companyName": "ExampleCompany",
  "productName": "Example Project",
  "bundleVersion": "1.0.0",
  "buildNumberStrategy": "github_run_number",

  "outputDirectory": "Builds",

  "scenes": [
    "Assets/Scenes/Main.unity"
  ],

  "scriptingBackend": "IL2CPP",
  "apiCompatibilityLevel": "NET_Standard_2_1",

  "developmentBuild": false,
  "allowDebugging": false,
  "connectProfiler": false,
  "deepProfiling": false,
  "cleanBuildCache": false,

  "runTests": true,

  "addressables": {
    "enabled": false,
    "profile": "Default",
    "buildRemoteCatalog": false
  },

  "android": {
    "applicationId": "com.example.project",
    "buildAppBundle": true,
    "minSdkVersion": 22,
    "targetSdkVersion": 34,
    "architecture": "ARM64",
    "keystoreMode": "custom",
    "symbolExport": "none"
  },

  "iOS": {
    "bundleIdentifier": "com.example.project",
    "marketingVersion": "1.0.0",
    "targetOSVersion": "14.0",
    "architecture": "ARM64",
    "developmentTeamId": "ABCDE12345",
    "signingStyle": "manual",
    "provisioningProfileSpecifier": "Example Project Distribution",
    "codeSignIdentity": "iPhone Distribution",
    "exportMethod": "app-store-connect",
    "enableBitcode": false,
    "generateSymbols": true,
    "uploadSymbols": true,
    "uploadToTestFlight": false,
    "generateXcodeProjectOnly": false
  },

  "windows": {
    "architecture": "x86_64",
    "outputName": "ExampleProject",
    "compressOutput": true
  },

  "webgl": {
    "compressionFormat": "Brotli",
    "decompressionFallback": true,
    "dataCaching": true,
    "memorySize": 256,
    "template": "Default",
    "outputName": "WebGL"
  },

  "gates": {
    "maxBuildSizeMB": 500,
    "warnBuildSizeIncreasePct": 10,
    "failBuildSizeIncreasePct": 25,
    "failOnWarnings": false,
    "requiredValidationRules": [
      "no_missing_references",
      "no_missing_scripts"
    ]
  },

  "metadata": {
    "repository": "https://github.com/<WORKFLOW_OWNER>/my-unity-project",
    "team": "your-team"
  },

  "hooks": {
    "preBuild": [],
    "postBuild": []
  }
}
