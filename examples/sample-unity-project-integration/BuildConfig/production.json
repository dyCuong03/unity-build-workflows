{
  "outputDirectory": "Builds/Production",
  "android": {
    "applicationId": "com.example.project",
    "buildAppBundle": true,
    "keystoreMode": "custom",
    "symbolExport": "public"
  },
  "gates": {
    "maxBuildSizeMB": 300,
    "warnBuildSizeIncreasePct": 5,
    "failBuildSizeIncreasePct": 15,
    "failOnWarnings": true
  },
  "metadata": {
    "environment": "production",
    "channel": "google-play",
    "repo": "example-project"
  }
}
