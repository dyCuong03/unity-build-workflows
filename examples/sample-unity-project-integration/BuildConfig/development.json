{
  "$schema": "../../../../schemas/unity-build-config.schema.json",
  "projectName": "my-unity-game",
  "companyName": "Acme Games",
  "productName": "My Unity Game",
  "bundleVersion": "1.0.0",
  "buildNumberStrategy": "github_run_number",
  "outputDirectory": "Builds/Development",
  "scenes": [
    "Assets/Scenes/Bootstrap.unity",
    "Assets/Scenes/MainMenu.unity",
    "Assets/Scenes/Level01.unity"
  ],
  "scriptingBackend": "Mono",
  "developmentBuild": true,
  "allowDebugging": true,
  "runTests": true,
  "android": {
    "applicationId": "com.acmegames.myunitygame.dev",
    "buildAppBundle": false,
    "minSdkVersion": 22,
    "targetSdkVersion": 34,
    "architecture": "ARM64",
    "keystoreMode": "debug"
  },
  "metadata": {
    "environment": "development",
    "repo": "my-unity-game"
  }
}
